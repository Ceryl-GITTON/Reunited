<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Titre principal -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💕 Reunited Countdown"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="6dp" />

    <!-- Compte à rebours en cartes (comme l'app) -->
    <LinearLayout
        android:id="@+id/widget_countdown_cards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="0dp">

        <!-- Carte Jours -->
        <LinearLayout
            android:id="@+id/card_days"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/time_card_background"
            android:padding="5dp"
            android:layout_marginEnd="3dp"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textColor="#AD1457"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="jours"
                android:textColor="#AD1457"
                android:textSize="8sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- Carte Heures -->
        <LinearLayout
            android:id="@+id/card_hours"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/time_card_background"
            android:padding="5dp"
            android:layout_marginEnd="3dp"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_hours"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textColor="#AD1457"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="heures"
                android:textColor="#AD1457"
                android:textSize="8sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- Carte Minutes -->
        <LinearLayout
            android:id="@+id/card_minutes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/time_card_background"
            android:padding="5dp"
            android:layout_marginEnd="3dp"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_minutes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textColor="#AD1457"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="min"
                android:textColor="#AD1457"
                android:textSize="8sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- Carte Secondes -->
        <LinearLayout
            android:id="@+id/card_seconds"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/time_card_background"
            android:padding="5dp"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_seconds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00"
                android:textColor="#AD1457"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="sec"
                android:textColor="#AD1457"
                android:textSize="8sp"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
